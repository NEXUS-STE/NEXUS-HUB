# App
NODE_ENV=development
PORT=3000
CORS_ORIGIN=http://localhost:5173

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/nexus_hub

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=change-me-in-production-use-32-chars-min
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Airtm
AIRTM_API_URL=https://api.airtm.com
AIRTM_API_KEY=
AIRTM_WEBHOOK_SECRET=

# Trustless Work (Stellar)
TRUSTLESS_WORK_API_URL=https://api.trustlesswork.com
TRUSTLESS_WORK_API_KEY=

# Platform fee (basis points, e.g. 100 = 1%)
PLATFORM_FEE_BPS=100
